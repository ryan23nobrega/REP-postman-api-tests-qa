{
  "info": {
    "_postman_id": "89c0a4d3-28aa-46c7-9ecd-726ac5786849",
    "name": "Fake Store API Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "20511373"
  },
  "item": [
    {
      "name": "Products",
      "item": [
        {
          "name": "GET - Get All Products",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is valid\", function () {\r",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 403]);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response time is less than 2000ms\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
                  "});\r",
                  "\r",
                  "if (pm.response.code === 200) {\r",
                  "    const responseJson = pm.response.json();\r",
                  "\r",
                  "    pm.test(\"Response body is an array\", function () {\r",
                  "        pm.expect(responseJson).to.be.an(\"array\");\r",
                  "    });\r",
                  "\r",
                  "    pm.test(\"Response has at least 1 product\", function () {\r",
                  "        pm.expect(responseJson.length).to.be.greaterThan(0);\r",
                  "    });\r",
                  "} else {\r",
                  "    pm.test(\"API may return 403 in CI environment\", function () {\r",
                  "        pm.expect(pm.response.code).to.eql(403);\r",
                  "    });\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/products",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "products"
              ]
            }
          },
          "response": []
        },
        {
          "name": "GET - Get Product By ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Response body is not empty\", function () {\r",
                  "    pm.expect(pm.response.text()).to.not.be.empty;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Status code is valid\", function () {\r",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 403]);\r",
                  "});\r",
                  "\r",
                  "if (pm.response.code === 200) {\r",
                  "    const responseJson = pm.response.json();\r",
                  "\r",
                  "    pm.test(\"Response body is an object\", function () {\r",
                  "        pm.expect(responseJson).to.be.an(\"object\");\r",
                  "    });\r",
                  "\r",
                  "    pm.test(\"Product has id\", function () {\r",
                  "        pm.expect(responseJson).to.have.property(\"id\");\r",
                  "    });\r",
                  "\r",
                  "    pm.test(\"Product id matches environment variable\", function () {\r",
                  "        pm.expect(responseJson.id).to.eql(Number(pm.environment.get(\"product_id\")));\r",
                  "    });\r",
                  "\r",
                  "    pm.test(\"Product has title\", function () {\r",
                  "        pm.expect(responseJson).to.have.property(\"title\");\r",
                  "    });\r",
                  "\r",
                  "    pm.test(\"Product price is greater than 0\", function () {\r",
                  "        pm.expect(responseJson.price).to.be.above(0);\r",
                  "    });\r",
                  "} else {\r",
                  "    pm.test(\"API may return 403 in CI environment\", function () {\r",
                  "        pm.expect(pm.response.code).to.eql(403);\r",
                  "    });\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/products/{{product_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "products",
                "{{product_id}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "POST - Create Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is valid\", function () {\r",
                  "    const validCodes = [200, 201];\r",
                  "\r",
                  "    if (!validCodes.includes(pm.response.code)) {\r",
                  "        console.log(\"Erro inesperado:\", pm.response.code);\r",
                  "        console.log(\"Resposta:\", pm.response.text());\r",
                  "    }\r",
                  "\r",
                  "    pm.expect(validCodes).to.include(pm.response.code);\r",
                  "});\r",
                  "\r",
                  "if (pm.response.code === 200 || pm.response.code === 201) {\r",
                  "    const responseJson = pm.response.json();\r",
                  "\r",
                  "    pm.test(\"Response body is an object\", function () {\r",
                  "        pm.expect(responseJson).to.be.an(\"object\");\r",
                  "    });\r",
                  "\r",
                  "    pm.test(\"Response has product title\", function () {\r",
                  "        pm.expect(responseJson.title).to.eql(\"Notebook Gamer\");\r",
                  "    });\r",
                  "\r",
                  "    pm.test(\"Response has product price\", function () {\r",
                  "        pm.expect(responseJson.price).to.eql(4500);\r",
                  "    });\r",
                  "\r",
                  "    pm.test(\"Response has category\", function () {\r",
                  "        pm.expect(responseJson.category).to.eql(\"electronics\");\r",
                  "    });\r",
                  "\r",
                  "    pm.test(\"Response has id\", function () {\r",
                  "        pm.expect(responseJson).to.have.property(\"id\");\r",
                  "    });\r",
                  "\r",
                  "    pm.environment.set(\"product_id\", responseJson.id);\r",
                  "    pm.environment.set(\"created_product_title\", responseJson.title);\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"title\": \"Notebook Gamer\",\r\n  \"price\": 4500,\r\n  \"description\": \"Produto criado para teste de API no Postman\",\r\n  \"image\": \"https://i.pravatar.cc\",\r\n  \"category\": \"electronics\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/products",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "products"
              ]
            }
          },
          "response": []
        }
      ]
    }
  ]
}